{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  // ============================================================
  // Lecture Factory - Model Routing Configuration
  // ============================================================
  // Single Source of Truth for all model routing decisions.
  // Categories define MODEL CAPABILITY TIERS, not agent aliases.
  //
  // Resolution flow:
  //   1. A0 Orchestrator reads .agent/AGENTS.md §Per-Agent Model Routing
  //   2. Looks up agent → category mapping
  //   3. This file resolves category → model
  //
  // Domain context (prompt_append) lives in each agent's .md file,
  // NOT in categories. Categories are pure model routing only.
  // ============================================================
  // === Agent-Level Model Overrides ===
  "agents": {
    // Main Orchestrator: Multi-pipeline coordination (8 pipelines)
    // Kimi K2.5 — Agent Swarm (100 sub-agents), tool-use #1, 256K context, ~30x cost reduction
    "sisyphus": {
      "model": "opencode-go/kimi-k2.5",
    },
    // Codebase Explorer: Pattern search within lecture materials
    // Fast & cheap - just grep/read operations
    "explore": {
      "model": "anthropic/claude-sonnet-4-6",
    },
    // Reference Researcher: Technical docs, library lookups
    // Anthropic Sonnet 4.6 — superior document parsing & structured output quality
    "librarian": {
      "model": "anthropic/claude-sonnet-4-6",
    },
    // Architecture Consultant: Curriculum/material structure review
    // Reasoning-specialized model for strategic decisions
    "oracle": {
      "model": "opencode/gpt-5.2",
      "variant": "high",
    },
    // Deep Executor: Complex autonomous goal-oriented tasks
    // Reasoning-specialized for multi-step implementation
    "hephaestus": {
      "model": "opencode/gpt-5.3-codex",
    },
  },
  // === Category-Level Model Routing (8 v2.0 Categories) ===
  // Used via task(category="...", prompt="...")
  // v2.0: GLM-5 retired, MiniMax M2.5 added, categories restructured.
  // See .agent/docs/agent-llm-optimal-mapping-v2.md for mapping details.
  "categories": {
    // --- orchestration-core ---
    // Pipeline coordination, workflow control, decision routing
    "orchestration-core": {
      "model": "anthropic/claude-sonnet-4-6",
    },
    // --- task-localization ---
    // Korean copy-editing, tone normalization, terminology management, traceability curation
    "task-localization": {
      "model": "anthropic/claude-sonnet-4-6",
    },
    // --- premium-production (was: deep-production) ---
    // Core writing, deep research, complex design requiring highest quality
    "premium-production": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
    },
    // --- long-context-prod (NEW: MiniMax M2.5) ---
    // Long-document writing, merge, reports — 1M context, $0.30/$1.20 per 1M tokens
    "long-context-prod": {
      "model": "opencode-go/minimax-2.5",
    },
    // --- visual-creative (was: creative-research) ---
    // Visual design, image prompts, creative work
    "visual-creative": {
      "model": "comet_qwen/qwen3.5-plus",
    },
    // --- strict-gatekeeper ---
    // Code/logic/citation verification, schema compliance, final QA
    "strict-gatekeeper": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
    },
    // --- mechanical-pipeline ---
    // Mechanical transforms, pipeline processing (parsing/rendering/assembly/submission)
    // Kimi K2.5 — tool-use specialized, Agent Swarm, ~10x cost reduction vs Sonnet
    "mechanical-pipeline": {
      "model": "opencode-go/kimi-k2.5",
    },
    // --- standard-production (NEW) ---
    // General writing, structure design, auxiliary content
    "standard-production": {
      "model": "anthropic/claude-sonnet-4-6",
    },
  },
}
